# Copy to .env and fill in real values

# --- Core ---
MONGO_URL=mongodb://127.0.0.1:27017/genius
PORT=4000
NODE_ENV=development
APP_URL=http://localhost:4000
JWT_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false

# --- Admin seed (only used when no user exists) ---
ADMIN_USER=admin
ADMIN_PASS=changeme

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Genius Appointments <no-reply@example.com>"

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- Calendly ---
CALENDLY_TOKEN=
CALENDLY_ORG_URI=
# Optional: owner's Calendly user URI (https://api.calendly.com/users/XXXX).
# Usually set in Settings → Owner; this env var is a fallback used by the
# reconcile script (npm run reconcile:calendly) so it can run headless.
CALENDLY_USER_URI=
CALENDLY_WEBHOOK_SECRET=
# Event Type URI Aria offers over the phone
# (https://api.calendly.com/event_types/XXXX). Used to read real availability
# and to mint the scheduling link the homeowner confirms. Usually set in
# Settings → Aria; this is a headless fallback.
CALENDLY_EVENT_TYPE_URI=

# --- ElevenLabs Conversational AI ("Aria" outbound calling) ---
# ElevenLabs places the call via their own managed Twilio integration, so no
# extra Twilio config is needed for voice. Leave blank to disable the Call
# button (everything else still works).
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
# HMAC secret verifying post-call webhooks at /api/webhooks/elevenlabs.
# Configure the same value in the ElevenLabs agent's webhook settings.
ELEVENLABS_WEBHOOK_SECRET=
# Shared secret the agent presents (x-aria-secret header) when it calls our
# availability / booking server tools mid-call. Set the same value on each
# tool in the ElevenLabs agent's Tools config. Leave blank to accept
# unsigned tool calls (dev only).
ARIA_TOOL_SECRET=

# --- Pacing (fallback global defaults; projects can override) ---
DEFAULT_PACING_MIN_SEC=30
DEFAULT_PACING_MAX_SEC=120
DEFAULT_REMINDER_DAYS=14
DEFAULT_MAX_REMINDERS=3
