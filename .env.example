# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./data/app.db"
NEXTAUTH_SECRET="replace-with-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# ── SMTP (Nodemailer) ─────────────────────────────────────────────────────────
# Required to send email. Leave unset to disable.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"          # "true" = implicit TLS (port 465). Otherwise STARTTLS.
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""                 # Defaults to SMTP_USER if omitted.

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
# All three are required to send SMS.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""        # e.g. +15551234567

# ── Calendly ──────────────────────────────────────────────────────────────────
# Personal access token + organisation URI. Required for the auto-match workflow.
CALENDLY_TOKEN=""
CALENDLY_ORG_URI=""          # e.g. https://api.calendly.com/organizations/XXXX
