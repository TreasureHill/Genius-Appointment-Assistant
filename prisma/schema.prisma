// Genius Appointment Assistant - data model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Rep {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  lots      Lot[]
}

model Project {
  id                   String   @id @default(cuid())
  name                 String   @unique
  description          String?
  reminderIntervalDays Int      @default(14)
  maxReminders         Int      @default(4)
  defaultEmailTemplateId String?
  defaultSmsTemplateId   String?
  createdAt            DateTime @default(now())
  lots                 Lot[]
}

model Lot {
  id               String    @id @default(cuid())
  projectId        String
  lotNumber        String
  address          String?
  status           String    @default("NEW") // NEW | CONTACTED | SCHEDULED | BOOKED | OPTED_OUT
  scheduledAt     DateTime?
  assignedRepId    String?
  reminderCount    Int       @default(0)
  lastContactedAt  DateTime?
  notes            String?
  rowHash          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedRep      Rep?      @relation(fields: [assignedRepId], references: [id])
  buyers           Buyer[]
  messageLogs      MessageLog[]
  outboxItems      OutboxItem[]
  calendlyEvents   CalendlyEvent[]

  @@unique([projectId, lotNumber])
  @@index([status])
  @@index([assignedRepId])
}

model Buyer {
  id     String  @id @default(cuid())
  lotId  String
  role   String  // PRIMARY | CO_BUYER | THIRD
  name   String
  email  String?
  phone  String?

  lot    Lot     @relation(fields: [lotId], references: [id], onDelete: Cascade)
  messageLogs MessageLog[]
  outboxItems OutboxItem[]
  calendlyEvents CalendlyEvent[]

  @@unique([lotId, role])
  @@index([email])
}

model Template {
  id        String   @id @default(cuid())
  type      String   // EMAIL | SMS
  name      String
  subject   String?
  bodyHtml  String?
  bodyText  String   @default("")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model MessageLog {
  id         String    @id @default(cuid())
  lotId      String
  buyerId    String
  channel    String    // EMAIL | SMS
  templateId String?
  subject    String?
  body       String
  status     String    // QUEUED | SENT | FAILED | DELIVERED
  providerId String?
  error      String?
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  lot   Lot   @relation(fields: [lotId], references: [id], onDelete: Cascade)
  buyer Buyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([channel, createdAt])
  @@index([lotId])
}

model OutboxItem {
  id         String    @id @default(cuid())
  lotId      String
  buyerId    String
  channel    String    // EMAIL | SMS
  templateId String?
  payload    String    // JSON: { to, subject?, html?, text }
  readyAt    DateTime
  attempts   Int       @default(0)
  lockedAt   DateTime?
  createdAt  DateTime  @default(now())

  lot   Lot   @relation(fields: [lotId], references: [id], onDelete: Cascade)
  buyer Buyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([readyAt])
  @@index([lockedAt])
}

model ImportBatch {
  id         String   @id @default(cuid())
  filename   String
  uploadedAt DateTime @default(now())
  added      Int      @default(0)
  updated    Int      @default(0)
  skipped    Int      @default(0)
  errorsJson String?
}

model CalendlyEvent {
  id              String    @id @default(cuid())
  inviteeEmail    String
  eventUri        String    @unique
  startTime       DateTime
  status          String    // ACTIVE | CANCELED
  matchedLotId    String?
  matchedBuyerId  String?
  receivedAt      DateTime  @default(now())

  matchedLot   Lot?   @relation(fields: [matchedLotId], references: [id])
  matchedBuyer Buyer? @relation(fields: [matchedBuyerId], references: [id])

  @@index([inviteeEmail])
  @@index([status])
}

model Setting {
  key   String @id
  value String // JSON blob
}
